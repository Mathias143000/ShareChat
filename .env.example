PORT=3000
APP_NODE_NAME=share-chat
PUBLIC_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=
ALLOWED_IPS_FILE=allowed_ips.txt

UPLOADS_DIR=uploads
DATA_DIR=data

MAX_UPLOAD_MB=200
MAX_UPLOAD_FILES=20
MAX_TOTAL_UPLOADS_MB=0
UPLOAD_RATE_LIMIT=20
UPLOAD_RATE_WINDOW_MS=60000
DELETE_RATE_LIMIT=10
DELETE_RATE_WINDOW_MS=60000

SOCKET_MAX_BUFFER_MB=10
MESSAGE_RATE_LIMIT=40
MESSAGE_RATE_WINDOW_MS=10000
CHAT_MESSAGE_LIMIT=1000
CHAT_INIT_LIMIT=200
CHAT_NAME_LIMIT=500
CHAT_MESSAGE_TTL_HOURS=168
CHAT_SAVE_DEBOUNCE_MS=500
STALE_UPLOAD_TTL_HOURS=0
UPLOAD_CLEANUP_INTERVAL_MINUTES=0

FILE_STAT_CONCURRENCY=8
FILE_DELETE_CONCURRENCY=4

ALLOW_EXTERNAL_IMAGE_URLS=false
MAX_IMAGE_DATAURL_MB=8
BLOCKED_UPLOAD_EXTS=exe,dll,com,bat,cmd,msi,ps1,scr,jar,php,asp,aspx,jsp,cgi,reg
# ALLOWED_UPLOAD_EXTS=txt,md,json,csv,png,jpg,jpeg,webp,mp4,mp3,pdf

STORAGE_BACKEND=disk
STORAGE_S3_BUCKET=
