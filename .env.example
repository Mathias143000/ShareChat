STORAGE_S3_PREFIX=uploads/
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_FORCE_PATH_STYLE=true

REDIS_URL=
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
