{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "rootDir": "src/server",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "baseUrl": ".",
    "paths": {
      "@sharechat/types": ["types/shared.d.ts"]
    }
  },
  "include": ["src/server/**/*.ts"]
}
