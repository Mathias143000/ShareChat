{
  "name": "sharechat",
  "version": "1.5.4",
  "private": true,
  "description": "ShareChat — файлы + мультичат с упоминаниями и вставкой изображений",
  "main": "dist/index.js",
  "scripts": {
    "build:client": "tsc -p tsconfig.client.json",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "bootstrap:env": "node scripts/bootstrap-env.js",
    "smoke": "node scripts/smoke-test.js",
    "compose:smoke": "node scripts/compose-smoke.js",
    "collect:logs": "node scripts/collect-logs.js",
    "test:install": "node scripts/install-integration.js",
    "test": "npm run build && npm run smoke && npm run test:install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.292.0",
    "express": "^4.22.1",
    "ioredis": "^5.10.0",
    "mime-types": "^2.1.35",
    "multer": "^2.1.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "socket.io-client": "^4.8.1",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0"
  }
}
